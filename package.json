{
  "name": "envctrl",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --enable-source-maps src/index.js",
    "build": "cd web && bunx vite build && cd .. && tsc -p tsconfig.json && cp src/storage/schema.sql dist/storage/schema.sql",
    "build:server": "tsc -p tsconfig.json",
    "build:web": "cd web && bunx vite build",
    "dev:web": "cd web && bunx vite",
    "dev:server": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.4",
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/eden": "^1.4.0",
    "@elysiajs/node": "^1.4.5",
    "@elysiajs/openapi": "^1.4.15",
    "@elysiajs/static": "^1.4.0",
    "@serialport/parser-delimiter": "^13.0.0",
    "@serialport/parser-readline": "^13.0.0",
    "@tanstack/react-query": "^5.101.2",
    "better-sqlite3": "^12.0.0",
    "elysia": "^1.4.0",
    "modbus-serial": "^8.0.25",
    "onoff": "^6.0.3",
    "pino": "^9.5.0",
    "serialport": "^13.0.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/bun": "^1.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/serialport": "^10.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/runner": "^4.1.9",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "trustedDependencies": [
    "epoll"
  ]
}